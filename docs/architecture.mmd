graph TB
    subgraph CLI["📟 CLI (mesh-id)"]
        direction LR
        C1["init"]
        C2["sync"]
        C3["scene"]
        C4["status"]
        C5["conflict"]
    end

    subgraph CORE["⚙️ 核心层"]
        direction TB
        DID["🔑 DID Manager
        身份生成/验证
        Ed25519 + soul_anchor"]
        SYNC["🔄 Memory Sync
        双向同步
        向量时钟 + 冲突检测"]
        SCENE["🎯 Scene Adapter
        场景自适应
        工作/个人/开发"]
    end

    subgraph STORAGE["💾 存储抽象层"]
        NAS["📁 NAS Storage
        SMB/NFS 抽象
        文件锁 + 健康检查"]
    end

    subgraph SHARED["🌐 共享存储 (NAS)"]
        D["did/
        DID凭证 公钥"]
        M["memory_vault/
        结构化记忆"]
        S["scene_config/
        场景配置"]
        L["lock/
        文件锁"]
    end

    C1 --> DID
    C2 --> SYNC
    C3 --> SCENE
    C4 --> SYNC
    C5 --> SYNC

    DID --> NAS
    SYNC --> NAS
    SCENE --> NAS

    NAS --> D
    NAS --> M
    NAS --> S
    NAS --> L

    subgraph TERMINALS["🖥️ 多终端"]
        T1["Windows Nyx"]
        T2["Mac Nyx"]
        T3["NAS Agent"]
    end

    TERMINALS --> SHARED

